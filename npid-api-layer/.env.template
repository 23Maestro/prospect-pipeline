# NPID API Layer Configuration
# Copy to .env and fill in your credentials

# NPID Dashboard
NPID_BASE_URL=https://dashboard.nationalpid.com

# Credentials (optional - falls back to these if ~/.npid_session.pkl doesn't exist)
# Normally, the Python client (src/python/npid_api_client.py) creates ~/.npid_session.pkl
# FastAPI reuses that session file, but will login with these credentials as fallback
NPID_EMAIL=your-email@example.com
NPID_PASSWORD=your-password

# API Key for scout-api endpoints
NPID_API_KEY=your-api-key

# Shared bearer token for Vercel/mobile proxy calls into FastAPI.
PROSPECT_API_TOKEN=change-me

# Tim Lite / Coach Risner pilot.
# Leave COACH_RISNER_ASSIGNED_TO empty to let Tim's logged-in session use its own task view.
# Set it only if the legacy dashboard requires a specific assignedto id.
COACH_RISNER_ASSIGNED_TO=

# Optional: Logging level (DEBUG for verbose output)
LOG_LEVEL=INFO
# Browser origins allowed to call API
ALLOWED_ORIGINS=https://recruiting-api.prospectid.com,http://localhost:3000,http://127.0.0.1:3000
