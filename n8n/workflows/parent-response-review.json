        "queryParameters": {
          "parameters": [
            {
              "name": "select",
              "value": "id,request_status,response_kind,approval_status,notification_status"
            },
            {
              "name": "request_status",
              "value": "in.(selected,none_work,ready_later)"
            },
            {
              "name": "approval_status",
              "value": "eq.pending"
            },
            {
              "name": "notification_status",
              "value": "neq.sent"
            },
            {
              "name": "order",
              "value": "updated_at.asc"
            },
            {
              "name": "limit",
              "value": "10"
