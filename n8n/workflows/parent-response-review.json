            {
              "name": "authorization",
              "value": "=Bearer {{$env.SUPABASE_SERVICE_ROLE_KEY}}"
            },
            {
              "name": "accept-profile",
              "value": "={{$env.SUPABASE_SCHEMA || 'public'}}"
            }
          ]
        },
        "options": {
          "response": {
            "response": {
              "responseFormat": "json"
            }
          }
        }
      },
      "id": "0f17b51b-9655-44ee-9fd4-51a1ba294002",
      "name": "Find submitted responses",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        -540,
        -20
      ]
    },
    {
      "parameters": {
        "jsCode": "const rows = Array.isArray($json) ? $json : (Array.isArray($json.body) ? $json.body : [$json]);\nreturn rows.filter((row) => row && row.id).map((row) => ({ json: row }));"
      },
      "id": "0f723194-05cd-40ef-beb8-ef2340dd3d1f",
      "name": "Normalize response rows",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -300,
        -20
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{$env.PARENT_RESPONSE_NOTIFY_BASE_URL.replace(/\\/$/, '') + '/api/parent-response/' + $json.id + '/notify'}}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "x-parent-response-secret",
              "value": "={{$env.PARENT_RESPONSE_NOTIFY_SECRET}}"
