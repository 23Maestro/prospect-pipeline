{
  "name": "prospect-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "node --import tsx --test tests/*.test.ts",
    "test:prospect-mobile": "node --import tsx --test --test-name-pattern \"prospect mobile\" tests/static-guards.test.ts",
    "verify": "npm run test && npm run build",
    "verify:prospect-mobile": "npm run test:prospect-mobile && npm run build",
    "deploy:prod": "npm run verify:prospect-mobile && npx vercel deploy --prod -y"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.86.0",
    "next": "^16.2.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
