  "knownActivityQuirk": {
    "problem": "Older rows from 2026-04-27 through 2026-04-30 have activity_kind null and legacy activity_type values like call_attempt or spoke_follow_up.",
    "whyItMatters": "The reporting view must normalize old vocabulary and always expose counts_as_dial, counts_as_contact, counts_as_meeting_set, and counts_as_post_meeting_outcome.",
    "lawGoingForward": "The stable contract needs separate reporting flags: countsAsDial, countsAsContact, countsAsMeetingSet, and countsAsPostMeetingOutcome. activity_kind can stay a simple storage bucket, but reporting cannot infer counts from that single column."
  }
}
