# Notion API Configuration
NOTION_API_KEY=your_notion_integration_token_here

# NPID Service Configuration
NPID_BASE_URL=https://dashboard.nationalpid.com
NPID_USERNAME=your_npid_username
NPID_PASSWORD=your_npid_password

# Scout API Key (for video stage and status updates)
SCOUT_API_KEY=your_scout_api_key_here

# Supabase lifecycle sync
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
SUPABASE_SCHEMA=public

# Dropbox API (optional - for file request creation)
DROPBOX_TOKEN=your_dropbox_token_here
