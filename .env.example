# Notion API Configuration
NOTION_API_KEY=your_notion_integration_token_here

# NPID Service Configuration
NPID_BASE_URL=https://dashboard.nationalpid.com
NPID_USERNAME=your_npid_username
NPID_PASSWORD=your_npid_password

# Mobile Netlify + Tailscale bridge
PROSPECT_API_TOKEN=shared_secret_for_netlify_proxy
ALLOWED_ORIGINS=https://your-netlify-site.netlify.app,http://localhost:8888,http://127.0.0.1:8888

# Scout API Key (for video stage and status updates)
SCOUT_API_KEY=your_scout_api_key_here

# Supabase lifecycle sync
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SECRET_KEY=your_supabase_secret_key_here
PARENT_RESPONSE_TOKEN_SECRET=your_parent_response_token_secret
PARENT_RESPONSE_PUBLIC_BASE_URL=https://prospect-web.vercel.app
SUPABASE_SCHEMA=public

# Internal bug notifications
RESEND_API_KEY=your_resend_api_key_here
BUG_NOTIFICATIONS_FROM=alerts@example.com
BUG_NOTIFICATIONS_TO=operator@example.com

# Dropbox API (optional - for file request creation)
DROPBOX_TOKEN=your_dropbox_token_here
